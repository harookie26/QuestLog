# MongoDB Atlas Data API configuration
# Create an App in Atlas > Data API and enable it, then create an API key.

# Full base URL for the Data API (no trailing /action). Replace <app-id> with your app id.
DATA_API_URL=https://data.mongodb-api.com/app/<app-id>/endpoint/data/v1
# Your Data API key (keep secret, do NOT commit to git)
MONGODB_URI=mongodb+srv://francismobina_db_user:fYBoosuTCVktFnkA@cluster0.c5mw07v.mongodb.net/GDAPDEV_grp?retryWrites=true&w=majority&appName=Cluster0

# The cluster name (dataSource) as shown in Atlas (default often Cluster0)
# MongoDB (Option A) - connect with a database user using MONGODB_URI
# Create a Database User in MongoDB Atlas with appropriate privileges (readWrite on your DB)
# Then set the connection string below. Keep this file out of source control.

DATA_SOURCE=Cluster0
# The database name used by your app
DATA_API_DB=questlog
# Collection name
DATA_API_COLLECTION=threads

# Existing variables kept for compatibility
PORT=5000

# Optional: if you still use MONGODB_URI for mongoose elsewhere
# MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.mongodb.net/yourDB?retryWrites=true&w=majority
# If you previously enabled Data API and want to keep keys, you can still add them here
# DATA_API_URL=https://data.mongodb-api.com/app/<app-id>/endpoint/data/v1
# DATA_API_KEY=your_data_api_key_here
